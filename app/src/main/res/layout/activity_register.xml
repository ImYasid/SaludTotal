<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <!-- Título de la pantalla -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear Cuenta"
            android:textColor="@color/salud_blue"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtítulo descriptivo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ingresa tus datos para registrarte. Es rápido y solo lo harás una vez."
            android:textColor="@color/text_subtitle"
            android:textSize="17sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Input de Cedula (corregido: teclado numérico, con id de contenedor para errores) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCedula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="@color/salud_teal"
            app:hintTextColor="@color/salud_teal"
            app:errorEnabled="true"
            app:helperTextEnabled="true"
            app:helperText="Son 10 números, sin espacios ni guiones"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCedula"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:textSize="20sp"
                android:hint="Número de cédula"
                android:inputType="number"
                android:maxLength="10"
                android:imeOptions="actionNext"
                android:contentDescription="Campo de número de cédula, 10 dígitos" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input de Nombres -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNombres"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="@color/salud_teal"
            app:hintTextColor="@color/salud_teal"
            app:errorEnabled="true"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombres"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:textSize="20sp"
                android:hint="Nombres Completos"
                android:inputType="textPersonName|textCapWords"
                android:imeOptions="actionNext"
                android:contentDescription="Campo de nombres completos" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input de Edad: ahora es de SOLO LECTURA, se llena únicamente con el calendario -->
        <!-- Esto evita que la persona escriba una fecha inválida a mano -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEdad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="@color/salud_teal"
            app:hintTextColor="@color/salud_teal"
            app:errorEnabled="true"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
            app:endIconTint="@color/salud_teal"
            app:helperTextEnabled="true"
            app:helperText="Toca aquí para elegir tu fecha de nacimiento en un calendario"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEdadRegistro"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:textSize="20sp"
                android:hint="Fecha de nacimiento"
                android:inputType="none"
                android:focusable="false"
                android:clickable="true"
                android:contentDescription="Toca para abrir el calendario y elegir tu fecha de nacimiento" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input de Correo Electrónico -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="@color/salud_teal"
            app:hintTextColor="@color/salud_teal"
            app:errorEnabled="true"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCorreoRegistro"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:textSize="20sp"
                android:hint="Correo Electrónico"
                android:inputType="textEmailAddress"
                android:imeOptions="actionNext"
                android:contentDescription="Campo de correo electrónico" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input de Contraseña con icono de "Ver/Ocultar" -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilContrasenaRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:boxStrokeColor="@color/salud_teal"
            app:hintTextColor="@color/salud_teal"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/salud_teal"
            app:errorEnabled="true"
            app:helperTextEnabled="true"
            app:helperText="Mínimo 6 letras o números"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContrasenaRegistro"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:textSize="20sp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                android:contentDescription="Campo de contraseña, mínimo 6 caracteres" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toca el ícono del ojo 👁 para ver la contraseña que escribiste"
            android:textColor="@color/text_subtitle"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Botón Principal de Registro -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrarCuenta"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Crear mi Cuenta"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/salud_teal"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Botón para regresar al Login -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolverLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="¿Ya tienes cuenta? Inicia sesión"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/salud_blue"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>
</ScrollView>