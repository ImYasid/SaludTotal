<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFBFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Botón Volver -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVolver"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Volver"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:textColor="#424D59"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@android:drawable/ic_menu_revert"
                    app:iconTint="#424D59"
                    app:iconGravity="textStart"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:contentDescription="Volver a elegir especialidad" />
            </RelativeLayout>

            <!-- Barra de Progreso Actualizada (Paso 2) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Paso 2 de 3: Elegir Médico"
                    android:textColor="@color/salud_blue"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Progreso al 66% -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/barraProgreso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="66"
                    app:trackColor="#E2E8F0"
                    app:indicatorColor="@color/salud_teal"
                    app:trackThickness="12dp"
                    app:trackCornerRadius="6dp" />
            </LinearLayout>

            <!-- Títulos Principales -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Con quién quieres tu\ncita?"
                android:textColor="#424D59"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <!-- NUEVO: recuerda qué especialidad se eligió, para que la persona no pierda el hilo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/salud_teal">

                <TextView
                    android:id="@+id/tvEspecialidadElegida"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Especialidad: Médico General"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Médicos más cercanos a ti"
                android:textColor="#9CA3AF"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Tarjeta Doctor 1: ahora TODA la tarjeta selecciona al médico, no solo el botón pequeño -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDoctor1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:contentDescription="Seleccionar al Doctor Juan Pérez">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:importantForAccessibility="no"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Juan Pérez"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="#6B7480"
                            android:importantForAccessibility="no"
                            android:layout_marginEnd="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Av. Principal #123, Centro"
                            android:textSize="14sp"
                            android:textColor="#6B7480"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.5 km de distancia"
                        android:textSize="14sp"
                        android:textColor="#3B82F6"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMapaDoctor1"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Cómo llegar"
                            android:textAllCaps="false"
                            app:icon="@android:drawable/ic_menu_directions"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:contentDescription="Ver cómo llegar al consultorio del Doctor Juan Pérez" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnElegirDoctor1"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Elegir Médico"
                            android:textAllCaps="false"
                            app:backgroundTint="#3B82F6" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta Doctor 2 (misma estructura, misma tarjeta completa tocable) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDoctor2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:contentDescription="Seleccionar a la Doctora María González">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:importantForAccessibility="no"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dra. María González"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="#6B7480"
                            android:importantForAccessibility="no"
                            android:layout_marginEnd="4dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calle Flores #456, Norte"
                            android:textSize="14sp"
                            android:textColor="#6B7480"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.2 km de distancia"
                        android:textSize="14sp"
                        android:textColor="#3B82F6"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMapaDoctor2"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Cómo llegar"
                            android:textAllCaps="false"
                            app:icon="@android:drawable/ic_menu_directions"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:contentDescription="Ver cómo llegar al consultorio de la Doctora María González" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnElegirDoctor2"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Elegir Médico"
                            android:textAllCaps="false"
                            app:backgroundTint="#3B82F6" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Barra de navegación inferior, con contentDescription para lectores de pantalla -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Ir al Inicio">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/baseline_home_filled_24"
                android:importantForAccessibility="no"
                app:tint="#2C6BFE" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="14sp"
                android:textColor="#6B7480"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAgendar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Volver a elegir especialidad">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/baseline_calendar_month_24"
                android:importantForAccessibility="no"
                app:tint="#2C6BFE" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agendar"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2C6BFE"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Cerrar sesión">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/outline_logout_24"
                android:importantForAccessibility="no"
                app:tint="#2C6BFE" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="14sp"
                android:textColor="#6B7480"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>