<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFBFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolver"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="Volver"
            android:textColor="#424D59"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconTint="#424D59" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Mis Citas"
            android:textColor="#424D59"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Aquí se inyectarán las tarjetas dinámicamente -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCitas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Mensaje que se muestra solo si la base de datos está vacía -->
    <TextView
        android:id="@+id/tvSinCitas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Aún no tienes citas agendadas."
        android:textColor="#A0A8B1"
        android:textSize="18sp"
        android:visibility="gone" />
</LinearLayout>