<?xml version="1.0" encoding="utf-8"?>
<!--
    CONTENEDOR RAÍZ: LinearLayout (Vertical)
    * Divide la pantalla en dos grandes bloques: el contenido deslizable (arriba)
      y la barra de navegación estática (abajo).
    * Fondo neutro (#FAFBFF) para reducir la fatiga visual y destacar los botones de colores.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFBFF">

    <!--
        CONTENEDOR DINÁMICO: NestedScrollView
        * 'android:layout_weight="1"' obliga a esta vista a ocupar todo el espacio disponible
          empujando la barra de navegación hacia el fondo absoluto de la pantalla.
        * Garantiza que en pantallas pequeñas el catálogo de especialidades no se corte.
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Contenedor interno del scroll con márgenes de respiro (padding 24dp) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!--
                NAVEGACIÓN DE RETORNO: Botón "Volver"
                * Se usa un MaterialButton estilo TextButton en lugar de un simple TextView
                  para aprovechar las animaciones táctiles (ripple effect) nativas.
                * Altura de 48dp cumple con las normas de accesibilidad táctil.
            -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVolver"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Volver"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:textColor="#424D59"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@android:drawable/ic_menu_revert"
                    app:iconTint="#424D59"
                    app:iconGravity="textStart"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:contentDescription="Volver a la pantalla anterior" />
            </RelativeLayout>

            <!--
                ORIENTACIÓN COGNITIVA: Barra de Progreso
                * Reduce la ansiedad del usuario al mostrar exactamente en qué parte del proceso se encuentra.
                * Diseño grueso (12dp) y bordes redondeados para máxima visibilidad.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Paso 1 de 3: Especialidad"
                    android:textColor="@color/salud_blue"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/barraProgreso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="33"
                    app:trackColor="#E2E8F0"
                    app:indicatorColor="@color/salud_teal"
                    app:trackThickness="12dp"
                    app:trackCornerRadius="6dp" />
            </LinearLayout>

            <!-- TITULACIÓN: Lenguaje empático y directo ("¿Qué te duele?") -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué te duele o qué\nnecesitas?"
                android:textColor="#424D59"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Toca una especialidad de la lista de abajo"
                android:textColor="#6B7480"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!--
                CONTROL DE BÚSQUEDA: Buscador en tiempo real
                * Encapsulado en un MaterialCardView para generar profundidad (elevación) y separar
                  la caja de texto del fondo de la aplicación.
                * Altura táctil generosa (52dp) para facilitar el enfoque del teclado.
            -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etBuscar"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Buscar especialidad..."
                        android:textColorHint="#A0A8B1"
                        android:paddingStart="16dp"
                        android:textSize="16sp"
                        android:inputType="text"
                        android:contentDescription="Buscar especialidad médica"/>

                    <!-- Disparador auxiliar: Preparado para futura integración de Speech-to-Text -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnMicrofono"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="#2C6BFE"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="Buscar por voz">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_btn_speak_now"
                            app:tint="#FFFFFF"
                            android:padding="10dp"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--
                CATÁLOGO DE SELECCIÓN: GridLayout
                * Divide el espacio uniformemente en 2 columnas ('android:columnCount="2"').
                * Botones extra grandes (130dp de altura) con colores contrastantes para
                  facilitar el mapeo cognitivo y evitar toques accidentales en la especialidad equivocada.
            -->
            <GridLayout
                android:id="@+id/gridEspecialidades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <!-- Botón Médico General -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMedicoGeneral"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Médico\nGeneral"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#3B82F6"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_search"
                    app:iconGravity="textTop"
                    app:iconSize="36dp"
                    app:iconTint="#FFFFFF" />

                <!-- Botón Cardiología -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCardiologia"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Cardiología"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#EF4444"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconGravity="textTop"
                    app:iconSize="36dp"
                    app:iconTint="#FFFFFF"/>

                <!-- Botón Traumatología -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTraumatologia"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Traumatología"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#F97316"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                    app:iconGravity="textTop"
                    app:iconSize="36dp"
                    app:iconTint="#FFFFFF"/>

                <!-- Botón Oftalmología -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOftalmologia"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Oftalmología"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#A855F7"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconGravity="textTop"
                    app:iconSize="36dp"
                    app:iconTint="#FFFFFF"/>

                <!-- Botón Neurología -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNeurologia"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Neurología"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6366F1"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_info_details"
                    app:iconGravity="textTop"
                    app:iconSize="36dp"
                    app:iconTint="#FFFFFF"/>

                <!-- Botón Vacunación -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVacunacion"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Vacunación"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#22C55E"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconGravity="textTop"
                    app:iconSize="36dp"
                    app:iconTint="#FFFFFF"/>

            </GridLayout>

            <!--
                ESTADO VACÍO (Empty State)
                * Elemento de contingencia que se activa ('visible') desde Kotlin si el TextWatcher
                  no encuentra coincidencias. Evita que el usuario crea que la app se congeló.
            -->
            <TextView
                android:id="@+id/tvSinResultados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No encontramos esa especialidad. Intenta con otra palabra."
                android:textColor="#A0A8B1"
                android:textSize="16sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!--
        BARRA DE NAVEGACIÓN INFERIOR (Bottom Navigation)
        * Fija en la base de la pantalla por jerarquía del LinearLayout principal.
        * Resalta el contexto actual ("Agendar") usando variaciones de color y peso tipográfico.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="8dp">

        <!-- Opción Inicio -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Ir al Inicio">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="26sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="14sp"
                android:textColor="#6B7480"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Opción Agendar (Estado Activo) -->
        <LinearLayout
            android:id="@+id/navAgendar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Ir a Agendar Cita">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="26sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agendar"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2C6BFE"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Opción Salir -->
        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Cerrar Sesión">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚪"
                android:textSize="26sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="14sp"
                android:textColor="#6B7480"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>